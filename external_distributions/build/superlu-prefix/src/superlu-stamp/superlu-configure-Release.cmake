
cmake_minimum_required(VERSION 3.15)

set(command "/usr/bin/cmake;--install-prefix=/home/zak3211/projects/oomph-lib/external_distributions/install/superlu;-DCMAKE_BUILD_TYPE=Release;-DTPL_ENABLE_METISLIB=ON;-DTPL_METIS_INCLUDE_DIRS=/home/zak3211/projects/oomph-lib/external_distributions/install/metis/include\;/home/zak3211/projects/oomph-lib/external_distributions/install/gklib/include;-DTPL_METIS_LIBRARIES=/home/zak3211/projects/oomph-lib/external_distributions/install/metis/lib/libmetis.a\;/home/zak3211/projects/oomph-lib/external_distributions/install/gklib/lib/libGKlib.a;-DTPL_BLAS_LIBRARIES=/home/zak3211/projects/oomph-lib/external_distributions/install/openblas/lib/libopenblas.a;-G=Ninja;-B=build")
set(log_merged "ON")
set(log_output_on_failure "ON")
set(stdout_log "/home/zak3211/projects/oomph-lib/external_distributions/build/logs/superlu-configure.log")
set(stderr_log "/home/zak3211/projects/oomph-lib/external_distributions/build/logs/superlu-configure.log")
execute_process(
  COMMAND ${command}
  RESULT_VARIABLE result
  OUTPUT_FILE "${stdout_log}"
  ERROR_FILE "${stderr_log}"
)
macro(read_up_to_max_size log_file output_var)
  file(SIZE ${log_file} determined_size)
  set(max_size 10240)
  if (determined_size GREATER max_size)
    math(EXPR seek_position "${determined_size} - ${max_size}")
    file(READ ${log_file} ${output_var} OFFSET ${seek_position})
    set(${output_var} "...skipping to end...\n${${output_var}}")
  else()
    file(READ ${log_file} ${output_var})
  endif()
endmacro()
if(result)
  set(msg "Command failed: ${result}\n")
  foreach(arg IN LISTS command)
    set(msg "${msg} '${arg}'")
  endforeach()
  if (${log_merged})
    set(msg "${msg}\nSee also\n  ${stderr_log}")
  else()
    set(msg "${msg}\nSee also\n  /home/zak3211/projects/oomph-lib/external_distributions/build/logs/superlu-configure-*.log")
  endif()
  if (${log_output_on_failure})
    message(SEND_ERROR "${msg}")
    if (${log_merged})
      read_up_to_max_size("${stderr_log}" error_log_contents)
      message(STATUS "Log output is:\n${error_log_contents}")
    else()
      read_up_to_max_size("${stdout_log}" out_log_contents)
      read_up_to_max_size("${stderr_log}" err_log_contents)
      message(STATUS "stdout output is:\n${out_log_contents}")
      message(STATUS "stderr output is:\n${err_log_contents}")
    endif()
    message(FATAL_ERROR "Stopping after outputting logs.")
  else()
    message(FATAL_ERROR "${msg}")
  endif()
else()
  if(NOT "Ninja" MATCHES "Ninja")
    set(msg "superlu configure command succeeded.  See also /home/zak3211/projects/oomph-lib/external_distributions/build/logs/superlu-configure-*.log")
    message(STATUS "${msg}")
  endif()
endif()
